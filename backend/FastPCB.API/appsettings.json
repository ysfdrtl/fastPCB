{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=3306;Database=fastpcb;User=root;Password=change-me;"
  },
  "Jwt": {
    "SecretKey": "your-secret-key-here-change-in-production",
    "Issuer": "fastpcb-api",
    "Audience": "fastpcb-client",
    "ExpirationInMinutes": 60
  },
  "FileStorage": {
    "ProjectUploadsPath": "uploads/projects",
    "MaxFileSizeInMb": 25,
    "AllowedExtensions": [
      ".zip",
      ".rar",
      ".7z",
      ".kicad_pcb",
      ".brd",
      ".gbr",
      ".ger",
      ".gerber",
      ".png",
      ".jpg",
      ".jpeg",
      ".pdf"
    ]
  },
  "Kafka": {
    "Enabled": false,
    "BootstrapServers": "localhost:9092",
    "ClientId": "fastpcb-api",
    "Topics": {
      "Projects": "fastpcb.projects",
      "Reports": "fastpcb.reports",
      "Users": "fastpcb.users"
    }
  },
  "Redis": {
    "Enabled": false,
    "ConnectionString": "localhost:6379",
    "InstanceName": "fastpcb:",
    "DefaultExpirationMinutes": 5
  }
}
