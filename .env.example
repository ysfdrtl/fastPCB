# Copy to .env for local Docker/development. Do not commit real production secrets.

ASPNETCORE_ENVIRONMENT=Development

MYSQL_DATABASE=fastpcb
MYSQL_ROOT_PASSWORD=change-me-local
MYSQL_PORT=3306

BACKEND_PORT=5000
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:5000/api

Jwt__SecretKey=replace-with-at-least-32-characters-local-key
Jwt__Issuer=fastpcb-api
Jwt__Audience=fastpcb-client
Jwt__ExpirationInMinutes=60

REDIS_ENABLED=true
REDIS_PORT=6379
Redis__Enabled=true
Redis__ConnectionString=localhost:6379
Redis__InstanceName=fastpcb:
Redis__DefaultExpirationMinutes=5

KAFKA_ENABLED=true
KAFKA_EXTERNAL_PORT=9094
Kafka__Enabled=true
Kafka__BootstrapServers=localhost:9094
Kafka__ClientId=fastpcb-api
Kafka__Topics__Projects=fastpcb.projects
Kafka__Topics__Reports=fastpcb.reports
Kafka__Topics__Users=fastpcb.users

FileStorage__ProjectUploadsPath=uploads/projects
